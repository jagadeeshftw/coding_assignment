# GitHub personal access token (optional; increases rate limit for POST /scan)
GITHUB_TOKEN=

# LLM for POST /analyze: openai | groq | ollama | gemini (default: openai)
LLM_PROVIDER=openai

# OpenAI (when LLM_PROVIDER=openai) – can hit quota; use groq/gemini/ollama as alternatives
OPENAI_API_KEY=

# Groq – free tier, fast (when LLM_PROVIDER=groq). Get key: https://console.groq.com
GROQ_API_KEY=

# Google Gemini – free tier (when LLM_PROVIDER=gemini). Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama – local, free (when LLM_PROVIDER=ollama). Run: ollama run llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# Server port (default 3000)
PORT=3000
